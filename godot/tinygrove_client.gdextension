[configuration]
entry_symbol = "gdext_rust_init"
compatibility_minimum = "4.2"

[libraries]
macos.debug = "res://bin/libtinygrove_client.dylib"
macos.release = "res://bin/libtinygrove_client.dylib"
linux.debug = "res://bin/libtinygrove_client.so"
linux.release = "res://bin/libtinygrove_client.so"
windows.debug.x86_64 = "res://bin/tinygrove_client.dll"
windows.release.x86_64 = "res://bin/tinygrove_client.dll"

